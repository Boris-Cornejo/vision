apiVersion: secrets-store.csi.x-k8s.io/v1
kind: SecretProviderClass
metadata:
  name: visionai-secret-provider-class
  namespace: visionai
spec:
  provider: aws
  parameters:
    objects: |
      - objectName: "visionai/sql-connection"
        objectType: "secretsmanager"
        objectAlias: "Storage__SqlConnectionString"
      - objectName: "visionai/tls-pfx-password"
        objectType: "secretsmanager"
        objectAlias: "Kestrel__Endpoints__Https__Certificate__Password"
